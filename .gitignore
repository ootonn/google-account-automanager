# Keep example files
!accounts_example.txt
!cards_example.txt
!proxies_example.txt

# Exclude database files
*.db
*.db-journal
*.sqlite
*.sqlite3

# Exclude log files
*.log

# Exclude debug/test files
debug_*.html
debug_*.png
step*.png
error*.png
age_verification_*.png

# Exclude all images by default
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.svg
*.ico

# Exception: Keep specific images
!联系_wx.png

# Exclude build artifacts and temp files
build/
dist/
*.spec
__pycache__/
*.pyc
temp_config.json
temp_icon.png

# Exclude IDE settings
.idea/
.vscode/
*.swp
*.swo
*~

# Exclude virtual env
venv/
env/
.venv/
.env/

# Exclude environment variables
.env
.env.local
.env.*.local
.env.production
.env.development

# Exclude Node.js dependencies and build
node_modules/
web/frontend/dist/
web/frontend/.vite/
web/frontend/.turbo/

# Exclude OS files
.DS_Store
Thumbs.db
desktop.ini
nul

# Exclude local git worktrees
.worktrees/
